{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "model.schema.json",
  "title": "Vehicle Dynamics Models File",
  "type": "object",
  "required": [
    "schema_version",
    "data_version",
    "model_groups",
    "models"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "data_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "model_groups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "model_group",
          "display_name",
          "description",
          "status"
        ],
        "properties": {
          "model_group": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "confirmed",
              "needs_review",
              "deprecated"
            ]
          }
        },
        "additionalProperties": false
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "model_name",
          "display_name",
          "model_group",
          "description",
          "status"
        ],
        "properties": {
          "model_name": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "display_name": {
            "type": "string",
            "minLength": 1
          },
          "model_group": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "confirmed",
              "needs_review",
              "deprecated"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
