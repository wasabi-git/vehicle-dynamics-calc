{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "unit.schema.json",
  "title": "Vehicle Dynamics Units File",
  "type": "object",
  "required": [
    "schema_version",
    "data_version",
    "units"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "data_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "display_symbol",
          "dimension",
          "canonical_si_unit",
          "si_conversion",
          "status"
        ],
        "properties": {
          "unit_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "display_symbol": {
            "type": "string",
            "minLength": 1
          },
          "dimension": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "canonical_si_unit": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "si_conversion": {
            "oneOf": [
              {
                "type": "object",
                "required": [
                  "type",
                  "scale",
                  "offset"
                ],
                "properties": {
                  "type": {
                    "const": "linear"
                  },
                  "scale": {
                    "type": "number",
                    "exclusiveMinimum": 0
                  },
                  "offset": {
                    "type": "number"
                  }
                },
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": [
                  "type",
                  "variable_id"
                ],
                "properties": {
                  "type": {
                    "const": "constant_reference"
                  },
                  "variable_id": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_]*$"
                  }
                },
                "additionalProperties": false
              }
            ]
          },
          "status": {
            "enum": [
              "confirmed",
              "needs_review",
              "deprecated"
            ]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
