  "formulas": [
    {
      "formula_id": "F001_wheel_radius_from_tire_size",
      "name": "Wheel radius from tire size",
      "description": "Calculates nominal unloaded wheel-and-tire radius from section width, aspect ratio, and rim diameter.",
      "source_reference": [
        {
          "source_id": "S001_vehicle_dynamics_formulae",
          "locator": "Ch 2 - Acceleration Performance",
          "note": "r_w = (195 × 0.55) / 25.4 + 16 / 2 example and corresponding general tire-size relation."
        }
      ],
      "status": "confirmed",
      "expression": "r_w = \\frac{w_s AR}{25.4} + \\frac{d_{rim}}{2}",
      "calculation_expression": "(section_width * aspect_ratio) / 25.4 + rim_diameter / 2",
      "formula_type": "algebraic",
      "computability": "direct",
      "expression_unit_mode": "source_native",
      "required_inputs": [
        "section_width",
        "aspect_ratio",
        "rim_diameter"
      ],
      "output": "wheel_radius",
      "model_group": "tire_and_wheel_geometry",
      "model_name": "tire_size_radius_model",
      "path_role": "primary",
      "priority": 10,
      "model_assumptions": [
        "Tire size gives nominal unloaded radius.",
        "Tire deflection under load is ignored."
      ],
      "allowed_assumption_inputs": [],
      "applicability_conditions": {
        "machine": {
          "all": []
        },
        "descriptive": [
          "The tire is represented by section width, aspect ratio, and rim diameter."
        ]
      },
      "formula_constraints": {
        "all": [
          {
            "operator": "gt",
            "variable": "section_width",
            "value": 0,
            "unit": "meter"
          },
          {
            "operator": "gt",
            "variable": "aspect_ratio",
            "value": 0,
            "unit": "decimal"
          },
          {
            "operator": "gt",
            "variable": "rim_diameter",
            "value": 0,
            "unit": "meter"
          }
        ]
      },
      "formula_family_id": "tire_size_radius",
      "model_type": "geometry_model",
      "substitution_units": {
        "section_width": "millimeter",
        "aspect_ratio": "decimal",
        "rim_diameter": "inch"
      },
      "native_output_unit": "inch",
      "known_limitations": [
        "The result is a nominal geometry-based radius, not a measured loaded or effective rolling radius."
      ],
      "notes": [
        "A tire-size string such as 195/55R16 is parsed by the input-preprocessing layer before this formula is evaluated."
      ]
    },
    {
      "formula_id": "F002_vehicle_speed_from_engine_speed",
      "name": "Vehicle speed from engine speed, wheel radius, and total gear ratio",
      "description": "Calculates vehicle speed from engine angular speed, wheel radius, and combined engine-to-wheel speed ratio.",
      "source_reference": [
        {
          "source_id": "S001_vehicle_dynamics_formulae",
          "locator": "Ch 2 - Acceleration Performance",
          "note": "V = r_w ω_e / N_tf"
        }
      ],
      "status": "confirmed",
      "expression": "V = \\frac{r_w \\omega_e}{N_{tf}}",
      "calculation_expression": "wheel_radius * engine_speed / combined_gear_ratio",
      "formula_type": "algebraic",
      "computability": "direct",
      "expression_unit_mode": "si_consistent",
      "required_inputs": [
        "wheel_radius",
        "engine_speed",
        "combined_gear_ratio"
      ],
      "output": "vehicle_speed",
      "model_group": "powertrain_kinematics",
      "model_name": "powertrain_speed_relation",
      "path_role": "primary",
      "priority": 10,
      "model_assumptions": [
        "No clutch slip.",
        "No torque-converter slip.",
        "No tire slip.",
        "Combined gear ratio is the total engine-to-wheel speed ratio."
      ],
      "allowed_assumption_inputs": [],
      "applicability_conditions": {
        "machine": {
          "all": []
        },
        "descriptive": [
          "The combined gear ratio corresponds to the selected gear and operating condition."
        ]
      },
      "formula_constraints": {
        "all": [
          {
            "operator": "gt",
            "variable": "wheel_radius",
            "value": 0,
            "unit": "meter"
          },
          {
            "operator": "gte",
            "variable": "engine_speed",
            "value": 0,
            "unit": "radian_per_second"
          },
          {
            "operator": "gt",
            "variable": "combined_gear_ratio",
            "value": 0,
            "unit": "decimal"
          }
        ]
      },
      "formula_family_id": "powertrain_speed_relation",
      "model_type": "kinematic_relation",
      "notes": [
        "v0.1 accepts combined_gear_ratio directly; transmission and final-drive ratios are not separately derived."
      ]
    },
    {
      "formula_id": "F003_engine_power_from_torque_rpm",
      "name": "Engine power from torque and engine speed",
      "description": "Calculates engine mechanical power from torque and engine speed using the course formula-sheet horsepower relation.",
      "source_reference": [
        {
          "source_id": "S001_vehicle_dynamics_formulae",
          "locator": "Ch 2 - Acceleration Performance",
          "note": "HP = T × RPM / 5252"
        }
      ],
      "status": "confirmed",
      "expression": "HP = \\frac{T_e \\cdot RPM}{5252}",
      "calculation_expression": "(engine_torque * engine_speed) / 5252",
      "formula_type": "algebraic",
      "computability": "direct",
      "expression_unit_mode": "source_native",
      "required_inputs": [
        "engine_torque",
        "engine_speed"
      ],
      "output": "engine_power",
      "model_group": "acceleration_performance",
      "model_name": "engine_power_calculation",
      "path_role": "primary",
      "priority": 10,
      "model_assumptions": [
        "Torque and engine speed refer to the same operating point."
      ],
      "allowed_assumption_inputs": [],
      "applicability_conditions": {
        "machine": {
          "all": []
        },
        "descriptive": []
      },
      "formula_constraints": {
        "all": [
          {
            "operator": "gte",
            "variable": "engine_torque",
            "value": 0,
            "unit": "newton_meter"
          },
          {
            "operator": "gte",
            "variable": "engine_speed",
            "value": 0,
            "unit": "radian_per_second"
          }
        ]
      },
      "formula_family_id": "engine_power",
      "model_type": "definition",
      "substitution_units": {
        "engine_torque": "foot_pound_force",
        "engine_speed": "revolution_per_minute"
      },
      "native_output_unit": "horsepower_mechanical",
      "known_limitations": [
        "The denominator 5252 is the rounded constant used by the course formula sheet."
      ],
      "notes": [
        "Do not substitute SI torque and angular-speed values directly into the source-native expression."
      ]
    },
    {
      "formula_id": "F004_tractive_force_from_engine_torque",
      "name": "Tractive force from engine torque",
      "description": "Calculates engine-and-drivetrain wheel tractive force from engine torque, combined gear ratio, drivetrain efficiency, and wheel radius.",
      "source_reference": [
        {
          "source_id": "S001_vehicle_dynamics_formulae",
          "locator": "Ch 2 - Acceleration Performance",
          "note": "F_x = T_e N_tf η_tf / r_w"
        }
      ],
      "status": "confirmed",
      "expression": "F_x = \\frac{T_e N_{tf} \\eta_{tf}}{r_w}",
      "calculation_expression": "engine_torque * combined_gear_ratio * drivetrain_efficiency / wheel_radius",
      "formula_type": "algebraic",
      "computability": "direct",
      "expression_unit_mode": "si_consistent",
      "required_inputs": [
        "engine_torque",
        "combined_gear_ratio",
        "drivetrain_efficiency",
        "wheel_radius"
      ],
      "output": "tractive_force",
      "model_group": "acceleration_performance",
      "model_name": "engine_tractive_force_at_wheels",
      "path_role": "primary",
      "priority": 10,
      "model_assumptions": [
        "Drivetrain efficiency is represented by η_tf.",
        "wheel_radius is used as the effective radius approximation.",
        "Tire slip and traction limits are not checked in v0.1."
      ],
      "allowed_assumption_inputs": [],
      "applicability_conditions": {
        "machine": {
          "all": []
        },
        "descriptive": []
      },
      "formula_constraints": {
        "all": [
          {
            "operator": "gte",
            "variable": "engine_torque",
            "value": 0,
            "unit": "newton_meter"
          },
          {
            "operator": "gt",
            "variable": "combined_gear_ratio",
            "value": 0,
            "unit": "decimal"
          },
          {
            "operator": "gt",
            "variable": "drivetrain_efficiency",
            "value": 0,
            "unit": "decimal"
          },
          {
            "operator": "lte",
            "variable": "drivetrain_efficiency",
            "value": 1,
            "unit": "decimal"
          },
          {
            "operator": "gt",
            "variable": "wheel_radius",
            "value": 0,
            "unit": "meter"
          }
        ]
      },
      "formula_family_id": "tractive_force",
      "model_type": "definition",
      "known_limitations": [
        "The calculated force is drivetrain-available force, not a tire-adhesion-limited maximum."
      ]
    },
    {
      "formula_id": "F005_mass_factor_from_total_gear_ratio",
      "name": "Mass factor from total gear ratio",
      "description": "Calculates the course empirical mass-factor approximation from combined gear ratio.",
      "source_reference": [
        {
          "source_id": "S001_vehicle_dynamics_formulae",
          "locator": "Ch 2 - Acceleration Performance",
          "note": "M_f = 1 + 0.04 N_tf + 0.0025 N_tf²"
        }
      ],
      "status": "confirmed",
      "expression": "M_f = 1 + 0.04N_{tf} + 0.0025N_{tf}^2",
      "calculation_expression": "1 + 0.04 * combined_gear_ratio + 0.0025 * combined_gear_ratio ^ 2",
      "formula_type": "empirical",
      "computability": "direct",
      "expression_unit_mode": "si_consistent",
      "required_inputs": [
        "combined_gear_ratio"
      ],
      "output": "mass_factor",
      "model_group": "acceleration_performance",
      "model_name": "mass_factor_approximation",
      "path_role": "primary",
      "priority": 10,
