{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "source.schema.json",
  "title": "Vehicle Dynamics Sources File",
  "type": "object",
  "required": [
    "schema_version",
    "data_version",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "data_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_id",
          "title",
          "type",
          "file_name",
          "status"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "pattern": "^S\\d{3}_[a-z0-9_]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "enum": [
              "formula_sheet",
              "textbook",
              "course_transcript",
              "standard",
              "other"
            ]
          },
          "file_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "confirmed",
              "needs_review",
              "deprecated"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
