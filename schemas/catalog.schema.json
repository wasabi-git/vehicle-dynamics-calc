{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog.schema.json",
  "title": "Vehicle Dynamics Catalog",
  "type": "object",
  "required": [
    "schema_version",
    "data_version",
    "catalog_id",
    "title",
    "files"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "data_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "catalog_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "role",
          "path",
          "required"
        ],
        "properties": {
          "role": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$"
          },
          "path": {
            "type": "string",
            "minLength": 1
          },
          "schema_path": {
            "type": "string",
            "minLength": 1
          },
          "required": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
