# Course source materials — copyrighted problem statements, never commit
validation/raw/

# Private provenance records (transcriptions, attributions, review trails) — never commit
validation/private/

# Share the Claude Code governance gate, while keeping machine-local settings private
!.claude/
.claude/*
!.claude/settings.json
